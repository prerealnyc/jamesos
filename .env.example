# Database
DATABASE_URL=postgresql://james_os:james_os@localhost:5433/james_os

# Tenant scoping (single tenant for v1)
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Embedding provider: voyage | openai | stub
EMBEDDING_PROVIDER=stub
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIM=1024
VOYAGE_API_KEY=

# LLM provider: anthropic | google | stub
LLM_PROVIDER=stub
LLM_MODEL=claude-opus-4-7
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Reranker (optional, falls back to no rerank if blank)
COHERE_API_KEY=

# App
LOG_LEVEL=INFO
