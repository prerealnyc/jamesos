# Database
# Local Docker (default):
DATABASE_URL=postgresql://james_os:james_os@localhost:5433/james_os
#
# Supabase: use the "Session pooler" or "Direct connection" string from
#   Supabase Dashboard → Project Settings → Database → Connection string.
#   (Do NOT use the Transaction pooler :6543 unless you also set
#   DB_STATEMENT_CACHE_SIZE=0 — it breaks our RLS set_config pattern.)
#   Example:
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# Connection tuning:
DB_SSL=prefer            # local: prefer | Supabase: require
DB_STATEMENT_CACHE_SIZE=256   # set 0 only for the :6543 transaction pooler

# Tenant scoping (single tenant for v1)
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Embedding provider: voyage | openai | stub
EMBEDDING_PROVIDER=stub
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIM=1024
VOYAGE_API_KEY=

# LLM provider: anthropic | google | stub
LLM_PROVIDER=stub
LLM_MODEL=claude-opus-4-7
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Reranker (optional, falls back to no rerank if blank)
COHERE_API_KEY=

# ─── Market research / internet intelligence ───
# Researches a subject on the open internet, ingests findings into the
# SAME memory substrate (category:research), citation-grounded.
# research_provider: perplexity | stub  (stub proves the loop with no key)
RESEARCH_PROVIDER=stub
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
# Google Custom Search JSON API (supplemental raw links)
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# App
LOG_LEVEL=INFO

# ─── Integration credentials (optional; available, not all wired) ───
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
DESCRIPT_API_KEY=
RUNWAY_API_KEY=
MINIMAX_API_KEY=
POSTPROXY_API_KEY=
META_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=
XPOZ_API_KEY=
